{
    "jsxSingleQuote": false,
    "singleQuote": false,
    "trailingComma": "all",
    "endOfLine": "lf",
    "printWidth": 100,
    "semi": false,
    "tabWidth": 4,
    "useTabs": false,
    "plugins": ["prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "src/index.css",
    "tailwindFunctions": ["cn", "cva"]
}
